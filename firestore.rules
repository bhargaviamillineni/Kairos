rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerifiedUser() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Task Validation
    function isValidTask(task) {
      return task.keys().hasAll(['title', 'deadline', 'priority', 'userId', 'completed'])
        && task.title is string && task.title.size() <= 500
        && task.deadline is string && task.deadline.size() <= 100
        && task.priority is string && (task.priority == 'low' || task.priority == 'medium' || task.priority == 'high')
        && task.completed is bool
        && task.userId == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow create: if isVerifiedUser() && isValidId(taskId) && isValidTask(request.resource.data);
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isVerifiedUser() && isValidId(taskId) && isValidTask(request.resource.data) && resource.data.userId == request.auth.uid;
    }

    // Goal Validation
    function isValidGoal(goal) {
      return goal.keys().hasAll(['title', 'progress', 'target', 'userId'])
        && goal.title is string && goal.title.size() <= 200
        && goal.progress is number && goal.progress >= 0
        && goal.target is number && goal.target > 0
        && goal.userId == request.auth.uid;
    }

    match /goals/{goalId} {
      allow create: if isVerifiedUser() && isValidId(goalId) && isValidGoal(request.resource.data);
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isVerifiedUser() && isValidId(goalId) && isValidGoal(request.resource.data) && resource.data.userId == request.auth.uid;
    }

    // Schedule Validation
    function isValidSchedule(schedule) {
      return schedule.keys().hasAll(['userId', 'date', 'plan'])
        && schedule.userId == request.auth.uid
        && schedule.date is string && schedule.date.size() <= 50
        && schedule.plan is list;
    }

    match /schedules/{scheduleId} {
      allow create: if isVerifiedUser() && isValidId(scheduleId) && isValidSchedule(request.resource.data);
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isVerifiedUser() && isValidId(scheduleId) && isValidSchedule(request.resource.data) && resource.data.userId == request.auth.uid;
    }
  }
}
